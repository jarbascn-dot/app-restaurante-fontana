rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net - Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global utility helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role verification helpers via reading /usuarios/{userId}
    function isUserAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'admin';
    }

    function isUserGestor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor';
    }

    function isUserFornecedor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == 'fornecedor';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Entity Schema Validators
    function isValidObra(data) {
      return data.keys().hasAll(['id', 'nome', 'centroCusto', 'ativa']) && 
             data.keys().size() <= 10 &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.centroCusto is string && data.centroCusto.size() <= 100 &&
             data.ativa is bool &&
             (!data.keys().hasAny(['valorRefeicao']) || data.valorRefeicao is number) &&
             (!data.keys().hasAny(['idFornecedorPrincipal']) || data.idFornecedorPrincipal is string) &&
             (!data.keys().hasAny(['cardapioUrl']) || (data.cardapioUrl is string && data.cardapioUrl.size() <= 2000000)) &&
             (!data.keys().hasAny(['cardapioNome']) || (data.cardapioNome is string && data.cardapioNome.size() <= 256)) &&
             (!data.keys().hasAny(['cardapioAtualizadoEm']) || (data.cardapioAtualizadoEm is string && data.cardapioAtualizadoEm.size() <= 128));
    }

    function isValidEmpresa(data) {
      return data.keys().hasAll(['id', 'nome', 'tipo']) &&
             data.keys().size() <= 4 &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             (data.tipo == 'Propria' || data.tipo == 'Terceirizada' || data.tipo == 'Prestadora');
    }

    function isValidUsuario(data) {
      return data.keys().hasAll(['id', 'nome', 'email', 'matricula', 'perfil', 'status', 'idEmpresa', 'idObraPadrao', 'criadoEm']) &&
             data.keys().size() <= 12 &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.email is string && data.email.size() <= 150 &&
             data.matricula is string && data.matricula.size() <= 100 &&
             (data.perfil == 'colaborador' || data.perfil == 'admin' || data.perfil == 'gestor' || data.perfil == 'fornecedor') &&
             (data.status == 'pendente' || data.status == 'aprovado' || data.status == 'desativado') &&
             data.idEmpresa is string && data.idObraPadrao is string &&
             (!data.keys().hasAny(['senha']) || data.senha is string) &&
             (!data.keys().hasAny(['idObrasFornecedor']) || data.idObrasFornecedor is list);
    }

    function isValidReserva(data) {
      return data.keys().hasAll(['id', 'idUsuario', 'data', 'status', 'consumido', 'idObraNoDia', 'alteradoEm', 'ipOrigem', 'dispositivo']) &&
             data.keys().size() <= 10 &&
             data.id is string && data.id.size() <= 128 &&
             data.idUsuario is string && data.idUsuario.size() <= 128 &&
             data.data is string && data.data.size() == 10 &&
             (data.status == 'reservado' || data.status == 'cancelado') &&
             data.consumido is bool &&
             data.idObraNoDia is string &&
             data.alteradoEm is string &&
             data.ipOrigem is string &&
             data.dispositivo is string;
    }

    function isValidFeriado(data) {
      return data.keys().hasAll(['id', 'data', 'descricao', 'tipo']) &&
             data.keys().size() <= 5 &&
             data.id is string && data.id.size() <= 128 &&
             data.data is string && data.data.size() == 10 &&
             data.descricao is string && data.descricao.size() <= 200 &&
             (data.tipo == 'nacional' || data.tipo == 'estadual' || data.tipo == 'municipal' || data.tipo == 'interno');
    }

    function isValidLog(data) {
      return data.keys().hasAll(['id', 'usuarioNome', 'usuarioEmail', 'dataHora', 'operacao', 'ip', 'dispositivo', 'perfil']) &&
             data.keys().size() <= 9 &&
             data.id is string && data.id.size() <= 128 &&
             data.usuarioNome is string && data.usuarioNome.size() <= 200 &&
             data.usuarioEmail is string && data.usuarioEmail.size() <= 150 &&
             data.dataHora is string &&
             data.operacao is string && data.operacao.size() <= 1000 &&
             data.ip is string && data.ip.size() <= 100 &&
             data.dispositivo is string && data.dispositivo.size() <= 200 &&
             (data.perfil == 'colaborador' || data.perfil == 'admin' || data.perfil == 'gestor' || data.perfil == 'fornecedor');
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['horarioLimite', 'permitirFinsDeSemana', 'valorRefeicaoPropria', 'valorRefeicaoTerceiro', 'usarTabletRetirada', 'requererBiometriaFacial', 'permitirSimulador']) &&
             data.keys().size() <= 8 &&
             data.horarioLimite is string &&
             data.permitirFinsDeSemana is bool &&
             data.valorRefeicaoPropria is number &&
             data.valorRefeicaoTerceiro is number &&
             data.usarTabletRetirada is bool &&
             data.requererBiometriaFacial is bool &&
             data.permitirSimulador is bool;
    }

    // 2. Collection Rules

    // Obras Collection
    match /obras/{obraId} {
      allow read: if true;
      allow write: if isValidId(obraId) && (request.method == 'delete' || isValidObra(incoming()));
    }

    // Empresas Collection
    match /empresas/{empresaId} {
      allow read: if true;
      allow write: if isValidId(empresaId) && (request.method == 'delete' || isValidEmpresa(incoming()));
    }

    // Usuarios Collection
    match /usuarios/{usuarioId} {
      allow read: if true;
      allow write: if isValidId(usuarioId) && (request.method == 'delete' || isValidUsuario(incoming()));
    }

    // Reservas Collection
    match /reservas/{reservaId} {
      allow read: if true;
      allow write: if isValidId(reservaId) && (request.method == 'delete' || isValidReserva(incoming()));
    }

    // Feriados Collection
    match /feriados/{feriadoId} {
      allow read: if true;
      allow write: if isValidId(feriadoId) && (request.method == 'delete' || isValidFeriado(incoming()));
    }

    // Logs Collection (Append-only logs of Audit)
    match /logs/{logId} {
      allow read: if true;
      allow create: if isValidId(logId) && isValidLog(incoming());
      allow update, delete: if false; // Append-only immutable logs
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isValidId(settingId) && isValidSettings(incoming());
      allow delete: if false;
    }

  }
}
